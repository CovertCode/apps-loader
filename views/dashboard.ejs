<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50">
<head>
    <%- include('partials/head', { title: 'Dashboard - HTML Hoster' }) %>
</head>
<body class="h-full font-sans text-gray-900 antialiased">

    <!-- Navigation -->
    <%- include('partials/navbar', { path: '/dashboard' }) %>

    <div class="py-10">
        <!-- Header -->
        <header class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
            <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Dashboard</h1>
            <p class="mt-2 text-sm text-slate-600">Manage your deployed applications and resources.</p>
        </header>

        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <!-- Global Error Display -->
            <% if (error) { %>
                <div class="rounded-lg bg-red-50 p-4 mb-8 border border-red-200 animate-pulse">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" /></svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-red-800">Action Failed</h3>
                            <div class="mt-2 text-sm text-red-700"><p><%= error %></p></div>
                        </div>
                    </div>
                </div>
            <% } %>

            <!-- Top Stats Component -->
            <%- include('components/stats') %>

            <!-- Main App Grid Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left: Deploy Form -->
                <div class="lg:col-span-1">
                    <%- include('components/deploy-form') %>
                </div>
                <!-- Right: App List -->
                <%- include('components/app-list') %>
            </div>

            <!-- Bookmarks Component -->
            <%- include('components/bookmarks') %>
        </main>
    </div>

    <!-- Page Specific Scripts -->
   <!-- Page Specific Scripts -->
    <script>
        // 1. Slug Sanitizer
        function sanitizeInput(input) {
            const slug = input.value.toString().normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim().replace(/[\s_]+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-');
            document.getElementById('slugPreview').textContent = slug ? '/sites/' + slug + '/' : 'Preview: ...';
        }

        // 2. File Input UI Update
        function updateFileName(input) {
            const display = document.getElementById('fileNameDisplay');
            if(input.files && input.files[0]) {
                display.textContent = input.files[0].name;
                display.className = 'text-xs font-semibold text-indigo-600';
            } else {
                display.textContent = '.html only';
                display.className = 'text-xs text-gray-500';
            }
        }

        // 3. Bookmark Logic
        
        // Helper: Toggle manual entry if fetch fails or user wants manual control
        function toggleMetadata() {
            const section = document.getElementById('metadataSection');
            section.classList.remove('hidden');
        }

        // Helper: Update icon preview image when input changes
        function updateIconPreview(url) {
            const img = document.getElementById('bmPreviewIcon');
            if (!url) {
                img.src = "https://via.placeholder.com/32?text=?";
            } else {
                img.src = url;
            }
        }

        async function fetchPreview() {
            const urlInput = document.getElementById('bookmarkUrl');
            let url = urlInput.value;
            const btn = document.getElementById('fetchBtn');
            const section = document.getElementById('metadataSection');
            
            if (!url || url.length < 4) return;

            // Basic protocol check for UX
            if (!url.startsWith('http')) {
                url = 'https://' + url;
                urlInput.value = url;
            }

            // UI Loading
            btn.textContent = '...';
            btn.disabled = true;
            
            try {
                const res = await fetch('/api/preview-url', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url })
                });
                const data = await res.json();

                // Reveal Section
                section.classList.remove('hidden');

                // Populate Visible Fields
                document.getElementById('bmTitle').value = data.title || '';
                document.getElementById('bmIcon').value = data.icon || '';
                
                // Update Icon Preview
                updateIconPreview(data.icon);

                btn.textContent = 'Fetched';
                setTimeout(() => { 
                    btn.textContent = 'Fetch'; 
                    btn.disabled = false; 
                }, 2000);

            } catch (e) {
                console.error(e);
                btn.textContent = 'Failed';
                // Even if failed, show section so user can type manually
                section.classList.remove('hidden');
                setTimeout(() => { 
                    btn.textContent = 'Fetch'; 
                    btn.disabled = false;
                }, 2000);
            }
        }
    </script>
</body>
</html>