<div class="relative py-12">
    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
    <div class="relative flex justify-center"><span class="px-4 bg-gray-50 text-lg font-medium text-gray-500">Bookmarks & Resources</span></div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-12">
    <!-- Form -->
    <div class="lg:col-span-1">
        <div class="bg-white shadow-sm border border-gray-200 rounded-xl p-5 sticky top-24">
            <h3 class="text-base font-semibold text-gray-900 mb-4 flex items-center justify-between">
                <span>Add Bookmark</span>
                <button type="button" onclick="toggleMetadata()" class="text-xs text-indigo-600 hover:text-indigo-800 underline">Manual Entry</button>
            </h3>
            
            <form action="/bookmarks/create" method="POST" class="space-y-4">
                <!-- URL Input -->
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Website URL</label>
                    <div class="flex rounded-lg shadow-sm">
                        <input type="url" id="bookmarkUrl" name="url" required placeholder="https://example.com" class="flex-1 block w-full rounded-none rounded-l-lg border-gray-300 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border p-2" onblur="fetchPreview()">
                        <button type="button" id="fetchBtn" onclick="fetchPreview()" class="inline-flex items-center px-3 rounded-r-lg border border-l-0 border-gray-300 bg-gray-50 text-gray-600 text-sm hover:bg-gray-100 font-medium transition-colors">
                            Fetch
                        </button>
                    </div>
                </div>
                
                <!-- Editable Metadata Section (Hidden by default until fetch) -->
                <div id="metadataSection" class="hidden space-y-4 pt-2 border-t border-gray-100 transition-all duration-300">
                    
                    <!-- Title Input -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Title</label>
                        <input type="text" name="title" id="bmTitle" class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2" placeholder="Site Title">
                    </div>

                    <!-- Icon Input & Preview -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Icon URL</label>
                        <div class="flex gap-2">
                            <div class="flex-shrink-0">
                                <img id="bmPreviewIcon" src="https://via.placeholder.com/32?text=?" class="h-10 w-10 rounded-lg border border-gray-200 bg-white p-1 object-contain">
                            </div>
                            <input type="text" name="icon" id="bmIcon" oninput="updateIconPreview(this.value)" class="block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border p-2" placeholder="https://.../favicon.ico">
                        </div>
                    </div>
                </div>

                <!-- Visibility Toggle -->
                <div class="flex items-center pt-2">
                    <input id="isPublic" name="isPublic" type="checkbox" checked class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                    <label for="isPublic" class="ml-2 block text-sm text-gray-900">Public on Homepage</label>
                </div>

                <button type="submit" id="saveBmBtn" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all">
                    Save Bookmark
                </button>
            </form>
        </div>
    </div>

    <!-- List (Unchanged from previous logic) -->
    <div class="lg:col-span-2">
        <% if (bookmarks.length === 0) { %>
             <div class="bg-white rounded-xl border-2 border-dashed border-gray-200 p-10 text-center">
                <svg class="mx-auto h-10 w-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                <span class="mt-2 block text-sm font-medium text-gray-500">No bookmarks saved yet.</span>
             </div>
        <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <% bookmarks.forEach(bm => { %>
                    <div class="group bg-white rounded-lg border border-gray-200 p-3 hover:border-indigo-300 hover:shadow-md transition-all flex items-start justify-between">
                        <a href="<%= bm.url %>" target="_blank" class="flex items-center gap-3 min-w-0 flex-1">
                            <img src="<%= bm.icon || 'https://www.google.com/s2/favicons?domain='+bm.url %>" class="w-9 h-9 rounded-md bg-gray-50 border border-gray-100 object-contain p-0.5" onerror="this.src='https://via.placeholder.com/32?text=?'">
                            <div class="min-w-0">
                                <h4 class="text-sm font-semibold text-gray-900 truncate group-hover:text-indigo-600"><%= bm.title || 'Untitled' %></h4>
                                <p class="text-xs text-gray-500 truncate"><%= new URL(bm.url).hostname %></p>
                            </div>
                        </a>
                        <form action="/bookmarks/delete" method="POST" class="ml-2">
                            <input type="hidden" name="id" value="<%= bm.id %>">
                            <button type="submit" class="text-gray-300 hover:text-red-500 p-1.5 rounded-md hover:bg-red-50 transition-colors" title="Delete">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </form>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</div>