<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - HTML Hoster</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen">

    <!-- Navbar -->
    <nav class="bg-white shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="text-xl font-bold text-indigo-600">HTML Hoster</div>
                <div class="space-x-4">
                    <% if (userToken) { %>
                        <a href="/dashboard" class="text-gray-700 hover:text-indigo-600 font-medium">Dashboard</a>
                        <a href="/logout" class="text-red-600 hover:text-red-800 font-medium">Logout</a>
                        <% } else { %>
                            <a href="/login" class="text-gray-700 hover:text-indigo-600 font-medium">Login</a>
                            <a href="/register"
                                class="bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 transition">Register</a>
                            <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl sm:tracking-tight lg:text-6xl">
                Host your Mini-Apps Instantly
            </h1>
            <p class="mt-5 max-w-xl mx-auto text-xl text-gray-500">
                Upload HTML files or code directly in the browser. Share your creations with the world.
            </p>
        </div>
    </div>

    <!-- Featured Apps Section -->
    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 mb-8">Featured Creations</h2>

        <% if (featuredApps.length===0) { %>
            <p class="text-gray-500 text-center py-10">No featured apps yet. Check back soon!</p>
            <% } else { %>
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                    <% featuredApps.forEach(app=> { %>
                        <div
                            class="bg-white overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-300 border border-gray-200">
                            <div class="px-4 py-5 sm:p-6">
                                <h3 class="text-lg leading-6 font-bold text-gray-900 truncate">
                                    <%= app.title || app.slug %>
                                </h3>
                                <div class="mt-2 text-sm text-gray-500">
                                    <p>By: <span class="font-semibold text-indigo-600">
                                            <%= app.author %>
                                        </span></p>
                                    <p class="text-xs text-gray-400 mt-1">Uploaded: <%= new
                                            Date(app.created_at).toLocaleDateString() %>
                                    </p>
                                </div>
                                <div class="mt-5">
                                    <a href="/sites/<%= app.slug %>/" target="_blank"
                                        class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200 w-full">
                                        View App
                                    </a>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } %>
    </div>

    <!-- Bookmarks Section -->
    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8 border-t border-gray-200">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900 mb-6">Community Bookmarks</h2>
        
        <% if (publicBookmarks.length === 0) { %>
            <p class="text-gray-500">No bookmarks shared yet.</p>
        <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <% publicBookmarks.forEach(bm => { %>
                    <a href="<%= bm.url %>" target="_blank" class="group bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-md hover:border-indigo-300 transition-all p-4 flex items-center space-x-4">
                        <div class="flex-shrink-0">
                            <img class="h-10 w-10 rounded object-contain bg-gray-50 border border-gray-100 p-1 group-hover:scale-110 transition-transform" 
                                 src="<%= bm.icon || 'https://www.google.com/s2/favicons?domain='+bm.url %>" 
                                 onerror="this.src='https://placehold.co/40x40'"
                                 alt="">
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-900 truncate group-hover:text-indigo-600">
                                <%= bm.title || 'Untitled' %>
                            </p>
                            <p class="text-xs text-gray-500 truncate">
                                <%= new URL(bm.url).hostname %>
                            </p>
                        </div>
                        <div class="flex-shrink-0 text-gray-300 group-hover:text-indigo-400">
                             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                        </div>
                    </a>
                <% }); %>
            </div>
        <% } %>
    </div>

</body>

</html>